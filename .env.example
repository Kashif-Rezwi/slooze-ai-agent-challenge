# ── Root .env — read by Docker Compose ────────────────────────────────────────
# Copy this file to .env and fill in your keys:
#
#   cp .env.example .env
#

# OpenAI
OPENAI_API_KEY=sk-...

# Tavily
TAVILY_API_KEY=tvly-...

# ChromaDB Cloud — https://trychroma.com
CHROMA_API_KEY=...
CHROMA_TENANT=...
CHROMA_DATABASE=default_database

# Optional — defaults shown
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
