{
  "name": "slooze-ai-challenges",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "shared:build": "pnpm --filter @slooze/shared build",
    "shared:typecheck": "pnpm --filter @slooze/shared typecheck",
    "backend:typecheck": "pnpm --filter backend typecheck",
    "backend:build": "pnpm --filter backend build",
    "frontend:typecheck": "pnpm --filter frontend typecheck",
    "frontend:build": "pnpm --filter frontend build",
    "typecheck": "pnpm shared:build && pnpm -r typecheck",
    "kill:ports": "kill-port 3000 3001 || true",
    "dev:frontend": "kill-port 3000 || true && pnpm --filter frontend dev",
    "dev:backend": "kill-port 3001 || true && pnpm --filter backend dev",
    "dev": "pnpm kill:ports && concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1"
  }
}
