# ── Required ───────────────────────────────────────────────────────────────────

# OpenAI — chat completions (gpt-4o-mini) + embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Tavily — real-time web search (Challenge A)
# Free tier: https://tavily.com  (1 000 searches / month)
TAVILY_API_KEY=tvly-...

# ChromaDB Cloud — hosted vector store for PDF RAG (Challenge B)
# Sign up free at https://trychroma.com → Dashboard → API Keys
# CHROMA_TENANT   : your tenant ID (shown on the dashboard home page)
# CHROMA_DATABASE : your database name (default is "default_database")
# CHROMA_API_KEY  : generated in Settings → API Keys
CHROMA_API_KEY=...
CHROMA_TENANT=...
CHROMA_DATABASE=default_database

# ── Optional (defaults shown) ──────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000

# RAG pipeline tuning (Challenge B)
CHUNK_SIZE=500      # characters per chunk
CHUNK_OVERLAP=50    # overlap between consecutive chunks
TOP_K_RESULTS=5     # number of chunks retrieved per RAG query
